{
  "manifest_version": 3,
  "name": "MarkItDown",
  "version": "1.1.0",
  "description": "Renders Markdown files in the browser with GitHub-style themes and GFM support.",

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "action": {
    "default_title": "Toggle Markdown rendering"
  },

  "background": {
    "service_worker": "src/background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "file:///*",
        "*://raw.githubusercontent.com/*",
        "*://gist.githubusercontent.com/*"
      ],
      "js": [
        "vendor/marked.min.js",
        "vendor/hljs.min.js",
        "src/content.js"
      ],
      "css": [
        "styles/markdown.css",
        "styles/hljs-theme.css"
      ],
      "run_at": "document_idle"
    }
  ],

  "permissions": [
    "activeTab"
  ]
}
